# ============================================================
# Required — API Server (artifacts/api-server)
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/bissi_db

# Port the API server listens on
PORT=5001

# Node environment: "development" | "production"
NODE_ENV=development

# ============================================================
# Required — Frontend (artifacts/bissi-app)
# Vite dev server — use a separate .env for this package
# ============================================================

# Port the Vite dev server listens on (defaults to 5173 if not set)
# PORT=5000

# Base URL path for the frontend (defaults to "/" if not set)
# BASE_PATH=/

# ============================================================
# Optional — Database (lib/db)
# ============================================================

# Max connections in the pool (default: 10)
DB_POOL_MAX=10

# Min idle connections in the pool (default: 2)
DB_POOL_MIN=2

# Set to "true" to force SSL (cloud DBs), "false" to disable (local dev)
# DATABASE_SSL=true

# ============================================================
# Optional — Security (api-server)
# ============================================================

# Comma-separated list of allowed CORS origins.
# REQUIRED in production — leave empty to allow all origins (safe behind a
# reverse proxy that already handles CORS).
# Example: CORS_ORIGINS=https://app.yourdomain.com
CORS_ORIGINS=

# Max requests per IP per minute for the global /api rate limiter (default: 300)
RATE_LIMIT_MAX=300

# ============================================================
# Optional — Logging
# ============================================================

# Log level: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# ============================================================
# Optional — Real-Time SMS Gateway (Fast2SMS / MSG91)
# ============================================================

# SMS Provider: "fast2sms" | "msg91"
SMS_PROVIDER=fast2sms

# Your SMS Gateway API key (e.g. Fast2SMS API key)
SMS_API_KEY=your_fast2sms_api_key_here
# FAST2SMS_API_KEY=your_fast2sms_api_key_here
# MSG91_TEMPLATE_ID=your_template_id


# Admin account credentials created by `pnpm --filter @workspace/scripts run seed`
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Administrator

