# ============================================================
# Required — API Server (artifacts/api-server)
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/bissi_db

# Port the API server listens on
PORT=5000

# ============================================================
# Required — Frontend (artifacts/bissi-app)
# ============================================================

# Port the Vite dev server listens on (defaults to 5173 if not set)
PORT=5173

# Base URL path for the frontend (defaults to "/" if not set)
BASE_PATH=/

# ============================================================
# Optional — Security (api-server)
# ============================================================

# Comma-separated list of allowed CORS origins.
# If not set, all origins are allowed (safe behind a reverse proxy; restrict in prod).
# Example: CORS_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGINS=

# ============================================================
# Optional — Seed script (scripts/)
# ============================================================

# Admin account credentials created by `pnpm --filter @workspace/scripts run seed`
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Administrator
